# Copy this file to `.env.local` and paste your key.
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional model overrides:
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_VIDEO_MODEL=veo-3.1-fast-generate-preview

# --- Orders backend ---
# Password to open the /admin dashboard
ADMIN_PASSWORD=change-me

# Production database (free at https://turso.tech). Local dev uses a file if unset.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_token
