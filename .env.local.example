# Copy this file to `.env.local` and paste your key.
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional model overrides:
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_VIDEO_MODEL=veo-3.1-fast-generate-preview

# --- Orders / Products / Coupons backend ---
# Password to open the /admin dashboard
ADMIN_PASSWORD=change-me

# Database (Neon Postgres) and image storage (Vercel Blob).
# On Vercel these are auto-injected when the Postgres + Blob stores are
# connected to the project. For local dev, run: vercel env pull .env.local
# POSTGRES_URL=postgres://...
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
